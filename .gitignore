# Python-generated files
__pycache__/
*.py[oc]
*.so
*.egg
*.egg-info/
dist/
build/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Virtual environments
backend/.venv
backend/venv/
frontend/node_modules/

# Python testing
.pytest_cache/
.coverage
htmlcov/

# Editor directories and files
.idea/
# keep per-repo VS Code extension recommendations but ignore other workspace files
.vscode/*
!.vscode/extensions.json
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment variables
.env
.env.local
backend/.env

# Node / Frontend
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.next/
frontend/coverage/
frontend/dist-ssr
*.local

# Database — ignore everything by default, un-ignore schema/seed
db/*
!db/schema.sql
!db/seed.sql
