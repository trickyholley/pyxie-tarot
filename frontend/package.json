{
  "name": "pyxie-tarot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "format:write": "oxfmt --write .",
    "lint": "oxlint",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.71.0",
    "rollup-plugin-visualizer": "^5.12.0",
    "terser": "^5.31.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  },
  "lint-staged": {
    "{frontend/src/**/*,.{js,jsx,ts,tsx}}": [
      "oxfmt --write",
      "oxlint"
    ],
    "*.json": [
      "oxfmt --write"
    ]
  }
}
